{
  "expo": {
    "name": "Lovely Kids",
    "slug": "lovely-kids",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lovely-kids",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E91E8C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lovelykids.nablus"
    },
    "android": {
      "package": "com.lovelykids.nablus",
      "backgroundColor": "#ABE2F6",
      "splash": {
        "image": "./assets/images/splash-android.png",
        "resizeMode": "contain",
        "backgroundColor": "#E91E8C"
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ABE2F6"
      },
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#E91E8C",
          "image": "./assets/images/icon.png",
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#E91E8C",
            "image": "./assets/images/splash-android.png",
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "enableSeparateBuildPerCPUArchitecture": true,
            "packagingOptions": {
              "pickFirst": [
                "META-INF/versions/9/OSGI-INF/MANIFEST.MF"
              ]
            }
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "supportsRTL": true,
      "forcesRTL": true,
      "eas": {
        "projectId": "29a18980-4b6d-44de-8c39-b2bbdd1385d5"
      },
      "router": {
        "origin": "https://replit.com/"
      }
    },
    "owner": "aymanshaheen"
  }
}
