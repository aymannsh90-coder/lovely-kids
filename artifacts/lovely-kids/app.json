{
  "expo": {
    "name": "Lovely Kids",
    "slug": "lovely-kids",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "lovely-kids",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E91E8C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lovelykids.nablus"
    },
    "android": {
      "package": "com.lovelykids.nablus",
      "backgroundColor": "#ABE2F6",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#ABE2F6"
      },
      "permissions": []
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "81cc3df4-73c9-4fb0-b5c3-32ef214b9d59"
      }
    }
  }
}
